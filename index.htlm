<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BEE PARFUMS 🐝</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Raleway:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --or: #c9a84c;
    --or2: #f0d080;
    --noir: #0a0a0a;
    --noir2: #141414;
    --blanc: #fdf8ee;
    --gris: #888;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--noir);
    color: var(--blanc);
    font-family: 'Raleway', sans-serif;
    font-weight: 300;
  }

  /* ── HERO ── */
  .hero {
    min-height: 100svh;
    background: radial-gradient(ellipse at 60% 40%, #2a1f00 0%, #0a0a0a 70%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 40px 24px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9a84c' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .bee-icon {
    font-size: 56px; margin-bottom: 16px;
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }
  .hero-title {
    font-family: 'Cinzel', serif;
    font-size: clamp(42px, 12vw, 80px);
    font-weight: 700;
    letter-spacing: 0.1em;
    background: linear-gradient(135deg, var(--or) 0%, var(--or2) 50%, var(--or) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: 8px;
  }
  .hero-sub {
    font-size: 11px; letter-spacing: 0.5em;
    color: var(--or); text-transform: uppercase;
    margin-bottom: 24px;
  }
  .hero-desc {
    font-size: 14px; color: rgba(253,248,238,0.6);
    line-height: 1.8; max-width: 340px;
    margin-bottom: 36px;
  }
  .hero-btn {
    display: inline-flex; align-items: center; gap: 10px;
    border: 1px solid var(--or);
    color: var(--or); padding: 14px 32px;
    font-family: 'Raleway', sans-serif;
    font-size: 10px; letter-spacing: 0.4em; text-transform: uppercase;
    text-decoration: none; cursor: pointer; background: transparent;
    transition: all 0.3s;
  }
  .hero-btn:hover { background: var(--or); color: var(--noir); }

  /* ── NAV SECTION ── */
  .section-nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(10,10,10,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(201,168,76,0.2);
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px;
  }
  .nav-logo {
    font-family: 'Cinzel', serif;
    font-size: 16px; font-weight: 600;
    background: linear-gradient(135deg, var(--or), var(--or2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cart-btn {
    display: flex; align-items: center; gap: 8px;
    background: var(--or); color: var(--noir);
    border: none; padding: 8px 16px;
    font-family: 'Raleway', sans-serif;
    font-size: 11px; font-weight: 500; cursor: pointer;
    letter-spacing: 0.1em;
    transition: opacity 0.2s;
  }
  .cart-btn:hover { opacity: 0.85; }
  #cart-count {
    background: var(--noir); color: var(--or);
    width: 18px; height: 18px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 700;
  }

  /* ── FILTRES ── */
  .filters {
    display: flex; gap: 8px; overflow-x: auto;
    padding: 16px 20px; scrollbar-width: none;
    border-bottom: 1px solid rgba(201,168,76,0.1);
  }
  .filters::-webkit-scrollbar { display: none; }
  .filter-btn {
    flex-shrink: 0;
    padding: 7px 16px; border: 1px solid rgba(201,168,76,0.3);
    background: transparent; color: rgba(253,248,238,0.6);
    font-family: 'Raleway', sans-serif;
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    cursor: pointer; transition: all 0.2s;
    white-space: nowrap;
  }
  .filter-btn.active, .filter-btn:hover {
    background: var(--or); color: var(--noir);
    border-color: var(--or);
  }

  /* ── SECTION TITRE ── */
  .section-header {
    padding: 40px 20px 20px;
    text-align: center;
  }
  .section-eyebrow {
    font-size: 9px; letter-spacing: 0.5em; color: var(--or);
    text-transform: uppercase; margin-bottom: 10px;
  }
  .section-title {
    font-family: 'Cinzel', serif;
    font-size: 28px; font-weight: 400;
    color: var(--blanc);
  }

  /* ── GRILLE PRODUITS ── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(201,168,76,0.1);
    padding: 1px;
  }
  .product-card {
    background: var(--noir2);
    position: relative;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.3s;
  }
  .product-card:hover { transform: scale(0.99); }
  .product-img {
    width: 100%; aspect-ratio: 1/1;
    object-fit: cover;
    transition: transform 0.5s;
    display: block;
  }
  .product-card:hover .product-img { transform: scale(1.05); }

  /* Overlay sur l'image */
  .product-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
    pointer-events: none;
  }

  /* Badge genre */
  .badge-genre {
    position: absolute; top: 10px; right: 10px;
    background: rgba(0,0,0,0.7);
    border: 1px solid var(--or);
    color: var(--or);
    font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
    padding: 4px 8px;
  }

  .product-info {
    padding: 12px 12px 16px;
  }
  .product-name {
    font-family: 'Cinzel', serif;
    font-size: 13px; font-weight: 400;
    color: var(--blanc);
    margin-bottom: 4px; line-height: 1.3;
  }
  .product-desc {
    font-size: 10px; color: var(--gris);
    line-height: 1.5; margin-bottom: 10px;
    font-style: italic;
  }
  .product-footer {
    display: flex; align-items: center; justify-content: space-between;
  }
  .product-price {
    font-family: 'Cinzel', serif;
    font-size: 15px; color: var(--or);
    font-weight: 600;
  }
  .add-btn {
    background: var(--or); color: var(--noir);
    border: none; width: 32px; height: 32px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px; cursor: pointer;
    transition: transform 0.2s, opacity 0.2s;
    font-weight: 300;
  }
  .add-btn:hover { transform: scale(1.1); opacity: 0.9; }
  .add-btn.added { background: #4caf50; }

  /* ── PANIER MODAL ── */
  .cart-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.7);
    z-index: 200; display: none; align-items: flex-end;
  }
  .cart-overlay.open { display: flex; }
  .cart-panel {
    width: 100%; background: var(--noir2);
    border-top: 2px solid var(--or);
    padding: 24px 20px;
    max-height: 80svh; overflow-y: auto;
    animation: slideUp 0.3s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }
  .cart-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 20px;
  }
  .cart-title {
    font-family: 'Cinzel', serif; font-size: 18px;
    color: var(--or);
  }
  .close-btn {
    background: none; border: 1px solid rgba(201,168,76,0.3);
    color: var(--blanc); width: 32px; height: 32px;
    font-size: 18px; cursor: pointer;
  }
  .cart-item {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(201,168,76,0.1);
  }
  .cart-item img {
    width: 50px; height: 50px; object-fit: cover;
    flex-shrink: 0;
  }
  .cart-item-info { flex: 1; }
  .cart-item-name { font-size: 13px; margin-bottom: 3px; }
  .cart-item-price { font-size: 12px; color: var(--or); }
  .remove-item {
    background: none; border: none; color: #c94e4e;
    font-size: 18px; cursor: pointer;
  }
  .cart-empty {
    text-align: center; padding: 30px 0;
    color: var(--gris); font-size: 13px;
  }
  .cart-total {
    margin-top: 16px;
    display: flex; justify-content: space-between; align-items: center;
    font-family: 'Cinzel', serif;
  }
  .cart-total-label { font-size: 14px; }
  .cart-total-price { font-size: 20px; color: var(--or); }
  .whatsapp-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%; padding: 16px;
    background: #25d366; color: #fff;
    border: none; margin-top: 16px;
    font-family: 'Raleway', sans-serif;
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; cursor: pointer;
    transition: opacity 0.2s;
  }
  .whatsapp-btn:hover { opacity: 0.9; }

  /* ── WHATSAPP FLOTTANT ── */
  .wa-float {
    position: fixed; bottom: 24px; right: 20px; z-index: 100;
    width: 52px; height: 52px; border-radius: 50%;
    background: #25d366;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,0.4);
    text-decoration: none; font-size: 24px;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 4px 20px rgba(37,211,102,0.4); }
    50% { box-shadow: 0 4px 30px rgba(37,211,102,0.7); }
  }

  /* ── FOOTER ── */
  footer {
    padding: 40px 20px;
    text-align: center;
    border-top: 1px solid rgba(201,168,76,0.2);
  }
  .footer-logo {
    font-family: 'Cinzel', serif; font-size: 22px;
    background: linear-gradient(135deg, var(--or), var(--or2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text; margin-bottom: 8px;
  }
  .footer-text { font-size: 11px; color: var(--gris); line-height: 1.7; }

  /* ── TOAST ── */
  .toast {
    position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%);
    background: var(--or); color: var(--noir);
    padding: 10px 24px; font-size: 12px; font-weight: 500;
    letter-spacing: 0.1em; z-index: 300;
    opacity: 0; transition: opacity 0.3s;
    pointer-events: none; white-space: nowrap;
  }
  .toast.show { opacity: 1; }
</style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="bee-icon">🐝</div>
  <h1 class="hero-title">BEE PARFUMS</h1>
  <p class="hero-sub">Collection de fragrances · Togo</p>
  <p class="hero-desc">Des parfums d'exception à prix accessible. Chaque flacon raconte une histoire unique.</p>
  <a href="#collection" class="hero-btn">Découvrir la collection ↓</a>
</section>

<!-- NAV STICKY -->
<div class="section-nav">
  <div class="nav-logo">🐝 BEE PARFUMS</div>
  <button class="cart-btn" onclick="openCart()">
    🛒 Panier <span id="cart-count">0</span>
  </button>
</div>

<!-- FILTRES -->
<div class="filters">
  <button class="filter-btn active" onclick="filterProducts('tous', this)">Tous</button>
  <button class="filter-btn" onclick="filterProducts('femme', this)">Femme</button>
  <button class="filter-btn" onclick="filterProducts('homme', this)">Homme</button>
  <button class="filter-btn" onclick="filterProducts('unisexe', this)">Unisexe</button>
</div>

<!-- COLLECTION -->
<section id="collection">
  <div class="section-header">
    <p class="section-eyebrow">Nos fragrances</p>
    <h2 class="section-title">Tous à 2 000 FCFA</h2>
  </div>
  <div class="product-grid" id="product-grid"></div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-logo">🐝 BEE PARFUMS</div>
  <p class="footer-text">
    Livraison disponible · Paiement à la livraison<br>
    Contactez-nous sur WhatsApp pour commander
  </p>
</footer>

<!-- WHATSAPP FLOTTANT -->
<a href="https://wa.me/+22890000000" class="wa-float" target="_blank">💬</a>

<!-- PANIER MODAL -->
<div class="cart-overlay" id="cart-overlay" onclick="closeCartOutside(event)">
  <div class="cart-panel">
    <div class="cart-header">
      <div class="cart-title">🛒 Mon Panier</div>
      <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div id="cart-items"></div>
    <div id="cart-footer" style="display:none">
      <div class="cart-total">
        <span class="cart-total-label">Total</span>
        <span class="cart-total-price" id="cart-total-price">0 FCFA</span>
      </div>
      <button class="whatsapp-btn" onclick="commanderWhatsApp()">
        💬 Commander via WhatsApp
      </button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">Ajouté au panier ✓</div>

<script>
const products = [
  { id:1,  name:"Rifaaqal",              genre:"unisexe", desc:"Floral oriental délicat",         img:"https://i.imgur.com/3tMWF5I.jpeg",  prix:2000 },
  { id:2,  name:"Marque Collection 122", genre:"unisexe", desc:"Eau de parfum 25ml",               img:"https://images.unsplash.com/photo-1590156206657-aec3e4429d10?w=400&q=80", prix:2000 },
  { id:3,  name:"Smart Collection 321",  genre:"unisexe", desc:"Canelle, cuir, bois, mousse",      img:"https://images.unsplash.com/photo-1599643478518-a784e5dc4c8f?w=400&q=80", prix:2000 },
  { id:4,  name:"Oniro",                 genre:"unisexe", desc:"Extra Long Lasting · 50ml",        img:"https://images.unsplash.com/photo-1592945403244-b3fbafd7f539?w=400&q=80", prix:2000 },
  { id:5,  name:"Marque Collection 214", genre:"homme",   desc:"Ambre, vanille, cèdre, oud",       img:"https://images.unsplash.com/photo-1547887538-e3a2f32cb1cc?w=400&q=80", prix:2000 },
  { id:6,  name:"Toomford Pour Homme",   genre:"homme",   desc:"Eau de parfum · 50ml · UAE",       img:"https://images.unsplash.com/photo-1541643600914-78b084683702?w=400&q=80", prix:2000 },
  { id:7,  name:"Marque Collection 113", genre:"femme",   desc:"Floral élégant pour elle",         img:"https://images.unsplash.com/photo-1563170351-be82bc888aa4?w=400&q=80", prix:2000 },
  { id:8,  name:"Extremely Unique",      genre:"unisexe", desc:"Eau de parfum · 50ml",             img:"https://images.unsplash.com/photo-1585386959984-a4155224a1ad?w=400&q=80", prix:2000 },
  { id:9,  name:"Lamsat",                genre:"unisexe", desc:"Smart World · 30ml",               img:"https://images.unsplash.com/photo-1523293182086-7651a899d37f?w=400&q=80", prix:2000 },
  { id:10, name:"Genie 6am",             genre:"unisexe", desc:"Eau de parfum · 25ml",             img:"https://images.unsplash.com/photo-1595425970377-c9703cf48b6d?w=400&q=80", prix:2000 },
  { id:11, name:"Marque Collection 150", genre:"unisexe", desc:"Maison Marque Collection · EDP",   img:"https://images.unsplash.com/photo-1571781926291-c477ebfd024b?w=400&q=80", prix:2000 },
  { id:12, name:"Oud Al Layl",           genre:"unisexe", desc:"Smart World · 30ml · Oriental",   img:"https://images.unsplash.com/photo-1557170334-a9632e77c6e4?w=400&q=80", prix:2000 },
  { id:13, name:"French Latte",          genre:"femme",   desc:"Floral fruité · 30ml",             img:"https://images.unsplash.com/photo-1528740561666-dc2479dc08ab?w=400&q=80", prix:2000 },
  { id:14, name:"Coco Vanilla Orchid",   genre:"femme",   desc:"Niche Fragrance Byredo · 50ml",    img:"https://images.unsplash.com/photo-1616020545467-f1e3e73e8f31?w=400&q=80", prix:2000 },
  { id:15, name:"Oud O'Clock",           genre:"unisexe", desc:"Genie Collection · 25ml",          img:"https://images.unsplash.com/photo-1594035910387-fea47794261f?w=400&q=80", prix:2000 },
];

let cart = [];
let currentFilter = 'tous';

function renderProducts(filter = 'tous') {
  const grid = document.getElementById('product-grid');
  const filtered = filter === 'tous' ? products : products.filter(p => p.genre === filter);
  grid.innerHTML = filtered.map(p => `
    <div class="product-card" data-genre="${p.genre}" data-id="${p.id}">
      <img class="product-img" src="${p.img}" alt="${p.name}" loading="lazy">
      <div class="product-overlay"></div>
      <span class="badge-genre">${p.genre}</span>
      <div class="product-info">
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <span class="product-price">2 000 FCFA</span>
          <button class="add-btn" id="btn-${p.id}" onclick="addToCart(${p.id})">+</button>
        </div>
      </div>
    </div>
  `).join('');
}

function addToCart(id) {
  const p = products.find(x => x.id === id);
  const existing = cart.find(x => x.id === id);
  if (existing) {
    existing.qty++;
  } else {
    cart.push({ ...p, qty: 1 });
  }
  updateCartCount();
  const btn = document.getElementById('btn-' + id);
  btn.textContent = '✓';
  btn.classList.add('added');
  setTimeout(() => { btn.textContent = '+'; btn.classList.remove('added'); }, 1500);
  showToast('Ajouté au panier ✓');
}

function updateCartCount() {
  const total = cart.reduce((s, x) => s + x.qty, 0);
  document.getElementById('cart-count').textContent = total;
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function openCart() {
  renderCart();
  document.getElementById('cart-overlay').classList.add('open');
}
function closeCart() {
  document.getElementById('cart-overlay').classList.remove('open');
}
function closeCartOutside(e) {
  if (e.target === document.getElementById('cart-overlay')) closeCart();
}

function renderCart() {
  const container = document.getElementById('cart-items');
  const footer = document.getElementById('cart-footer');
  if (cart.length === 0) {
    container.innerHTML = '<div class="cart-empty">Ton panier est vide 🐝</div>';
    footer.style.display = 'none';
    return;
  }
  container.innerHTML = cart.map(item => `
    <div class="cart-item">
      <img src="${item.img}" alt="${item.name}">
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name} × ${item.qty}</div>
        <div class="cart-item-price">${(item.prix * item.qty).toLocaleString()} FCFA</div>
      </div>
      <button class="remove-item" onclick="removeItem(${item.id})">✕</button>
    </div>
  `).join('');
  const total = cart.reduce((s, x) => s + x.prix * x.qty, 0);
  document.getElementById('cart-total-price').textContent = total.toLocaleString() + ' FCFA';
  footer.style.display = 'block';
}

function removeItem(id) {
  cart = cart.filter(x => x.id !== id);
  updateCartCount();
  renderCart();
}

function commanderWhatsApp() {
  if (cart.length === 0) return;
  const lignes = cart.map(x => `- ${x.name} × ${x.qty} = ${(x.prix * x.qty).toLocaleString()} FCFA`).join('\n');
  const total = cart.reduce((s, x) => s + x.prix * x.qty, 0);
  const msg = `🐝 *Commande BEE PARFUMS*\n\n${lignes}\n\n*Total : ${total.toLocaleString()} FCFA*\n\nJe voudrais commander svp !`;
  const url = `https://wa.me/+22890000000?text=${encodeURIComponent(msg)}`;
  window.open(url, '_blank');
}

function filterProducts(genre, btn) {
  currentFilter = genre;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(genre);
}

// Init
renderProducts();
</script>
</body>
</html>
